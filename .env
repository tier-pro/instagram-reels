PORT=3000
NODE_ENV=development
CORS_ORIGIN=*
RAPIDAPI_KEY=your_rapidapi_key_here
# ===== INSTAGRAM COOKIES (REQUIRED FOR SCRAPING) =====
# How to get cookies:
# 1. Login to Instagram in browser
# 2. Open Developer Tools (F12) > Application > Cookies
# 3. Copy the sessionid cookie value
# 4. Paste it below (format: sessionid=YOUR_SESSION_ID)
INSTAGRAM_COOKIE=sessionid=YOUR_INSTAGRAM_SESSION_ID_HERE
MAX_DOWNLOADS_PER_IP=50
CACHE_TTL=3600
AD_CLIENT=ca-pub-XXXXXXXXXXXXXXXX
GA_MEASUREMENT_ID=G-XXXXXXXXXX
RECAPTCHA_SITE_KEY=your_recaptcha_site_key
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key
