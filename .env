# ─── InstaSavvy CONFIG ───
# Instagram now REQUIRES authentication for ALL access methods.
# Without a cookie, download WILL FAIL.

# HOW TO GET YOUR INSTAGRAM COOKIE:
# 1. Open Chrome/Edge and go to instagram.com — LOG IN to your account
# 2. Open DevTools (F12) → Application tab (Chrome) or Storage tab (Edge)
# 3. Expand "Cookies" → click "instagram.com"
# 4. Right-click any cookie → "Show All" or similar
# 5. Select ALL rows (Ctrl+A), copy, and paste into the field below
#    The format should look like:
#    csrftoken=abc123...; sessionid=xyz456...; ds_user_id=12345...;
#
#    Or use this extension: "EditThisCookie" — export as Netscape format
#
# IMPORTANT: The cookie must be from a LOGGED-IN session.
# Without this, Instagram returns 403/500 errors on all endpoints.
INSTAGRAM_COOKIE=

PORT=3000
